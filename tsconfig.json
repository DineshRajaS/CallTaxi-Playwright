{
  "compilerOptions": {
    // "target":        "ES2020",
    "target": "ESNext",
    "moduleResolution": "node",
    "types": ["node", "playwright"],
    "module":        "commonjs",
    "lib":           ["ES2020"],
    "strict":        true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir":        "./dist",
    "rootDir":       "./src",
    "baseUrl":       ".",
    "paths": {
      "@pages/*":    ["src/pages/*"],
      "@utils/*":    ["src/utils/*"],
      "@testData/*": ["src/testData/*"],
      "@fixtures/*": ["src/fixtures/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
